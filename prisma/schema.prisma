generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  FINANCE
  WELFARE_STAFF
  ACADEMIC
  DATA_ENTRY
}

enum ReceiptType {
  M1
  M4_GENERAL
  M4_LANG
}

enum DocumentRequestStatus {
  PENDING
  COMPLETED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(FINANCE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  importBatches       ImportBatch[]
  receipts            Receipt[]            @relation("GeneratedReceipts")
  unpaidConfirmations Receipt[]            @relation("UnpaidConfirmations")
  distributions       WelfareDistribution[]
}

model Student {
  id            String      @id @default(cuid())
  studentCode   String      @unique
  prefix        String
  firstName     String
  lastName      String
  level         String
  room          String
  receiptType   ReceiptType
  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])
  createdAt     DateTime    @default(now())

  receipts          Receipt[]
  distributions     WelfareDistribution[]
  documentRequests  DocumentRequest[]

  @@index([level, room])
  @@index([importBatchId])
  @@index([firstName, lastName])
  @@index([receiptType])
}

model ImportBatch {
  id            String   @id @default(cuid())
  fileName      String
  importedById  String
  importedBy    User     @relation(fields: [importedById], references: [id])
  importedAt    DateTime @default(now())
  totalStudents Int

  students Student[]

  @@index([importedById])
}

model Receipt {
  id            String      @id @default(cuid())
  receiptNumber String      @unique
  studentId     String
  student       Student     @relation(fields: [studentId], references: [id])
  receiptType   ReceiptType
  totalAmount   Float
  barcodeData   String
  paidAt              DateTime?
  generatedAt         DateTime    @default(now())
  generatedById       String
  generatedBy         User        @relation("GeneratedReceipts", fields: [generatedById], references: [id])
  unpaidConfirmedAt   DateTime?
  unpaidConfirmedById String?
  unpaidConfirmedBy   User?       @relation("UnpaidConfirmations", fields: [unpaidConfirmedById], references: [id])

  @@index([studentId])
  @@index([paidAt])
  @@index([unpaidConfirmedAt])
  @@index([generatedById])
  @@index([receiptNumber])
  @@index([receiptType])
  @@index([paidAt, unpaidConfirmedAt])
  @@index([studentId, paidAt])

  documentRequests DocumentRequest[]
}

model WelfareItem {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)

  distributions WelfareDistribution[]
}

model WelfareDistribution {
  id                String   @id @default(cuid())
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id])
  itemId            String
  item              WelfareItem @relation(fields: [itemId], references: [id])
  received          Boolean  @default(true)
  notReceivedReason String?
  pendingSize       String?
  scannedById       String
  scannedBy         User     @relation(fields: [scannedById], references: [id])
  scannedAt         DateTime @default(now())

  @@index([studentId])
  @@index([itemId])
  @@index([received])
  @@index([received, itemId])
  @@index([received, scannedAt])
  @@unique([studentId, itemId])
}

model DocumentRequest {
  id            String                @id @default(cuid())
  studentId     String
  student       Student               @relation(fields: [studentId], references: [id])
  receiptId     String
  receipt       Receipt               @relation(fields: [receiptId], references: [id])
  studentName   String
  requestRound  Int
  status        DocumentRequestStatus @default(PENDING)
  pickupDate    DateTime?
  note          String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([status])
  @@index([requestRound])
  @@index([createdAt])
  @@unique([studentId, receiptId])
}
